generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String            @id @default(cuid())
  email               String            @unique
  displayName         String
  role                String
  membershipPlanId    String?
  membershipExpiresAt DateTime?
  referredAt          DateTime?
  referredByAgentId   String?
  sessions            Session[]
  membershipOrders    MembershipOrder[]
  contentOrders       ContentOrder[]
  coinAccount         CoinAccount?
  coinRechargeOrders  CoinRechargeOrder[]
  agentApplications   AgentApplication[]
  agentProfile        AgentProfile?     @relation("AgentAccount")
  adminAuditLogs      AdminAuditLog[]
  referredByAgent     AgentProfile?     @relation("AgentReferralUsers", fields: [referredByAgentId], references: [id], onDelete: SetNull)
  agentCommissionLedgers AgentCommissionLedger[]
  assistantConversations AssistantConversation[]
  assistantHandoffRequests AssistantHandoffRequest[]
  adminExportTasks    AdminExportTask[]
  financeReconciliationIssues FinanceReconciliationIssue[] @relation("FinanceIssueCreatedByUser")
  loginActivities     UserLoginActivity[]
  membershipEvents    UserMembershipEvent[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([referredByAgentId, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserLoginActivity {
  id         String   @id @default(cuid())
  source     String   @default("passwordless-demo")
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([source, createdAt])
}

model UserMembershipEvent {
  id                  String   @id @default(cuid())
  action              String
  planId              String?
  previousPlanId      String?
  previousExpiresAt   DateTime?
  nextExpiresAt       DateTime?
  note                String?
  createdByDisplayName String?
  createdAt           DateTime @default(now())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model MembershipOrder {
  id               String   @id @default(cuid())
  planId           String
  amount           Int
  status           String   @default("pending")
  provider         String   @default("mock")
  providerOrderId  String?
  expiresAt        DateTime?
  callbackPayload  String?
  paymentReference String?
  paidAt           DateTime?
  failedAt         DateTime?
  failureReason    String?
  closedAt         DateTime?
  refundedAt       DateTime?
  refundReason     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerOrderId])
  @@index([status, updatedAt])
}

model ContentOrder {
  id               String   @id @default(cuid())
  contentId        String
  amount           Int
  status           String   @default("pending")
  provider         String   @default("mock")
  providerOrderId  String?
  expiresAt        DateTime?
  callbackPayload  String?
  paymentReference String?
  paidAt           DateTime?
  failedAt         DateTime?
  failureReason    String?
  closedAt         DateTime?
  refundedAt       DateTime?
  refundReason     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerOrderId])
  @@index([status, updatedAt])
}

model CoinAccount {
  id               String             @id @default(cuid())
  balance          Int                @default(0)
  lifetimeCredited Int                @default(0)
  lifetimeDebited  Int                @default(0)
  lastActivityAt   DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgers          CoinLedger[]

  @@index([balance, updatedAt])
}

model CoinLedger {
  id             String      @id @default(cuid())
  direction      String
  reason         String
  amount         Int
  balanceBefore  Int
  balanceAfter   Int
  referenceType  String?
  referenceId    String?
  note           String?
  expiresAt      DateTime?
  createdAt      DateTime    @default(now())
  accountId      String
  account        CoinAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([referenceType, referenceId])
  @@index([reason, createdAt])
}

model CoinPackage {
  id              String              @id @default(cuid())
  key             String              @unique
  titleZhCn       String
  titleZhTw       String
  titleEn         String
  descriptionZhCn String?
  descriptionZhTw String?
  descriptionEn   String?
  coinAmount      Int
  bonusAmount     Int                 @default(0)
  price           Int
  validityDays    Int?
  badge           String?
  status          String              @default("active")
  sortOrder       Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  rechargeOrders  CoinRechargeOrder[]

  @@index([status, sortOrder])
}

model CoinRechargeOrder {
  id               String      @id @default(cuid())
  orderNo          String      @unique
  coinAmount       Int
  bonusAmount      Int         @default(0)
  amount           Int
  status           String      @default("pending")
  provider         String      @default("manual")
  providerOrderId  String?
  expiresAt        DateTime?
  callbackPayload  String?
  paymentReference String?
  paidAt           DateTime?
  failedAt         DateTime?
  failureReason    String?
  closedAt         DateTime?
  refundedAt       DateTime?
  refundReason     String?
  creditedAt       DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  packageId        String
  userId           String
  package          CoinPackage @relation(fields: [packageId], references: [id], onDelete: Restrict)
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentCommissionLedgers AgentCommissionLedger[]
  financeReconciliationIssues FinanceReconciliationIssue[]

  @@unique([provider, providerOrderId])
  @@index([status, updatedAt])
  @@index([userId, updatedAt])
  @@index([packageId, updatedAt])
}

model PaymentCallbackEvent {
  id               String   @id @default(cuid())
  provider         String   @default("mock")
  providerEventId  String?
  eventKey         String   @unique
  orderType        String
  orderId          String?
  providerOrderId  String?
  paymentReference String?
  state            String
  processingStatus String   @default("received")
  processingMessage String?
  payload          String?
  duplicateCount   Int      @default(0)
  lastSeenAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([provider, createdAt])
  @@index([processingStatus, lastSeenAt])
  @@index([orderType, orderId])
}

model AgentApplication {
  id                 String       @id @default(cuid())
  applicantName      String
  phone              String
  contact            String?
  channelSummary     String
  expectedMonthlyUsers Int?
  desiredLevel       String
  status             String       @default("pending")
  reviewerNote       String?
  reviewedAt         DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  userId             String?
  approvedAgentId    String?
  user               User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  approvedAgent      AgentProfile? @relation(fields: [approvedAgentId], references: [id], onDelete: SetNull)

  @@index([status, updatedAt])
  @@index([userId, updatedAt])
}

model AgentProfile {
  id                  String             @id @default(cuid())
  displayName         String
  level               String
  status              String             @default("active")
  inviteCode          String             @unique
  inviteUrl           String?
  commissionRate      Float              @default(0)
  downstreamRate      Float              @default(0)
  contactName         String?
  contactPhone        String?
  channelSummary      String?
  payoutAccount       String?
  totalReferredUsers  Int                @default(0)
  monthlyRechargeAmount Int              @default(0)
  totalCommission     Int                @default(0)
  unsettledCommission Int                @default(0)
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  userId              String?            @unique
  parentAgentId       String?
  user                User?              @relation("AgentAccount", fields: [userId], references: [id], onDelete: SetNull)
  parentAgent         AgentProfile?      @relation("AgentHierarchy", fields: [parentAgentId], references: [id], onDelete: SetNull)
  childAgents         AgentProfile[]     @relation("AgentHierarchy")
  referredUsers       User[]             @relation("AgentReferralUsers")
  approvedApplications AgentApplication[]
  withdrawals         AgentWithdrawal[]
  leads               RecruitmentLead[]
  commissionLedgers   AgentCommissionLedger[]

  @@index([status, level, updatedAt])
  @@index([parentAgentId, updatedAt])
}

model AgentCommissionLedger {
  id               String            @id @default(cuid())
  kind             String            @default("direct")
  rechargeAmount   Int
  commissionRate   Float             @default(0)
  commissionAmount Int
  settledAmount    Int               @default(0)
  reversedAmount   Int               @default(0)
  status           String            @default("pending")
  note             String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  settledAt        DateTime?
  reversedAt       DateTime?
  agentId          String
  sourceAgentId    String?
  sourceAgentName  String?
  userId           String
  rechargeOrderId  String
  agent            AgentProfile      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  rechargeOrder    CoinRechargeOrder @relation(fields: [rechargeOrderId], references: [id], onDelete: Cascade)
  allocations      AgentWithdrawalAllocation[]

  @@unique([rechargeOrderId, agentId, kind])
  @@index([agentId, status, createdAt])
  @@index([rechargeOrderId, kind, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model AgentCampaign {
  id                String            @id @default(cuid())
  name              String
  description       String?
  incentivePolicy   String?
  targetAgentCount  Int               @default(0)
  startsAt          DateTime?
  endsAt            DateTime?
  isPublic          Boolean           @default(false)
  status            String            @default("draft")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  leads             RecruitmentLead[]

  @@index([status, updatedAt])
}

model RecruitmentLead {
  id              String         @id @default(cuid())
  name            String
  phone           String
  sourceChannel   String
  desiredLevel    String
  status          String         @default("new")
  note            String?
  ownerName       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  campaignId      String?
  agentId         String?
  campaign        AgentCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  agent           AgentProfile?  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([status, updatedAt])
  @@index([campaignId, updatedAt])
  @@index([agentId, updatedAt])
}

model AgentWithdrawal {
  id             String       @id @default(cuid())
  amount         Int
  status         String       @default("pending")
  payoutAccount  String?
  payoutChannel  String?
  payoutBatchNo  String?
  payoutReference String?
  payoutOperator String?
  payoutRequestedAt DateTime?
  callbackStatus String?
  callbackPayload String?
  callbackReceivedAt DateTime?
  note           String?
  proofUrl       String?
  requestedAt    DateTime     @default(now())
  reviewedAt     DateTime?
  settledAt      DateTime?
  rejectionReason String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  agentId        String
  agent          AgentProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)
  allocations    AgentWithdrawalAllocation[]

  @@index([status, updatedAt])
  @@index([agentId, updatedAt])
  @@index([payoutBatchNo, updatedAt])
}

model AgentWithdrawalAllocation {
  id                 String                @id @default(cuid())
  amount             Int
  createdAt          DateTime              @default(now())
  withdrawalId       String
  commissionLedgerId String
  withdrawal         AgentWithdrawal       @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)
  commissionLedger   AgentCommissionLedger @relation(fields: [commissionLedgerId], references: [id], onDelete: Cascade)

  @@index([withdrawalId, createdAt])
  @@index([commissionLedgerId, createdAt])
}

model AdminRolePolicy {
  id                    String   @id @default(cuid())
  role                  String   @unique
  description           String?
  canAccessAdminConsole Boolean  @default(false)
  canManageContent      Boolean  @default(false)
  canManageFinance      Boolean  @default(false)
  canManageAgents       Boolean  @default(false)
  canManageSystem       Boolean  @default(false)
  canViewReports        Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AdminAuditLog {
  id               String   @id @default(cuid())
  actorDisplayName String
  actorRole        String
  action           String
  scope            String
  targetType       String?
  targetId         String?
  status           String   @default("success")
  detail           String?
  ipAddress        String?
  createdAt        DateTime @default(now())
  actorUserId      String?
  actorUser        User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([scope, createdAt])
  @@index([status, createdAt])
  @@index([actorUserId, createdAt])
}

model SystemAlertChannel {
  id              String   @id @default(cuid())
  name            String
  provider        String
  target          String
  severityFilter  String   @default("warn,error")
  status          String   @default("active")
  note            String?
  lastTriggeredAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  alertEvents     SystemAlertEvent[]

  @@index([status, updatedAt])
}

model SystemAlertEvent {
  id          String              @id @default(cuid())
  source      String
  title       String
  message     String
  severity    String              @default("warn")
  status      String              @default("open")
  detail      String?
  createdAt   DateTime            @default(now())
  resolvedAt  DateTime?
  channelId   String?
  channel     SystemAlertChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([severity, createdAt])
  @@index([channelId, createdAt])
}

model SystemParameter {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String   @default("general")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, updatedAt])
}

model AdminExportTask {
  id                     String   @id @default(cuid())
  scope                  String
  status                 String   @default("queued")
  requestedByDisplayName String
  filtersJson            String?
  filename               String?
  storageType            String   @default("local")
  storageKey             String?
  mimeType               String   @default("text/csv")
  rowCount               Int      @default(0)
  sizeBytes              Int?
  errorText              String?
  downloadCount          Int      @default(0)
  startedAt              DateTime?
  finishedAt             DateTime?
  expiresAt              DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  requestedByUserId      String?
  requestedByUser        User?    @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([requestedByUserId, createdAt])
  @@index([scope, createdAt])
}

model AdminReportDailyFact {
  id           String   @id @default(cuid())
  metricDate   DateTime
  scope        String   @default("overview")
  metricKey    String
  dimensionKey String   @default("")
  countValue   Int      @default(0)
  amountValue  Int      @default(0)
  extraJson    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([metricDate, scope, metricKey, dimensionKey])
  @@index([metricDate])
  @@index([scope, metricKey, metricDate])
}

model FinanceReconciliationIssue {
  id                    String             @id @default(cuid())
  scope                 String             @default("coin-recharge")
  issueType             String             @default("manual_review")
  status                String             @default("open")
  severity              String             @default("medium")
  workflowStage         String             @default("triage")
  summary               String
  detail                String?
  reasonCode            String?
  paymentReference      String?
  amount                Int?
  sourceStatus          String?
  resolutionNote        String?
  assignedToDisplayName String?
  reminderCount         Int                @default(0)
  lastRemindedAt        DateTime?
  lastReminderNote      String?
  createdByDisplayName  String
  resolvedAt            DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  rechargeOrderId       String?
  createdByUserId       String?
  rechargeOrder         CoinRechargeOrder? @relation(fields: [rechargeOrderId], references: [id], onDelete: SetNull)
  createdByUser         User?              @relation("FinanceIssueCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([status, updatedAt])
  @@index([severity, updatedAt])
  @@index([scope, updatedAt])
  @@index([rechargeOrderId, updatedAt])
  @@index([createdByUserId, updatedAt])
}

model League {
  id               String             @id @default(cuid())
  source           String             @default("nowscore")
  sourceKey        String?
  sourcePayload    String?
  sport            String
  slug             String             @unique
  name             String
  displayName      String?
  region           String
  season           String
  status           String             @default("active")
  featured         Boolean            @default(false)
  sortOrder        Int                @default(0)
  adminLockedFields String?
  adminOverrideJson String?
  adminNote        String?
  adminEditedAt    DateTime?
  lastSyncedAt     DateTime?
  teams            Team[]
  matches          Match[]
  standings        StandingSnapshot[]
  schedules        ScheduleSnapshot[]
  headToHeads      HeadToHeadSnapshot[]
  articlePlans     ArticlePlan[]
  homepageModules  HomepageModule[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([source, sourceKey])
  @@index([sport, featured, sortOrder])
  @@index([sport, status, sortOrder])
  @@index([updatedAt, adminEditedAt])
}

model Team {
  id            String             @id @default(cuid())
  source        String             @default("nowscore")
  sourceKey     String?
  sourcePayload String?
  sport         String
  slug          String
  name          String
  displayName   String?
  shortName     String
  ranking       Int?
  form          String?
  homeRecord    String?
  awayRecord    String?
  lastSyncedAt  DateTime?
  leagueId      String
  league        League             @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  homeMatches   Match[]            @relation("MatchHomeTeam")
  awayMatches   Match[]            @relation("MatchAwayTeam")
  standings     StandingSnapshot[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([leagueId, slug])
  @@unique([source, sourceKey])
  @@index([leagueId, ranking])
}

model Match {
  id            String             @id @default(cuid())
  source        String             @default("nowscore")
  sourceKey     String?
  sourcePayload String?
  sport         String
  slug          String?
  status        String
  kickoff       DateTime
  clock         String?
  venue         String
  leagueId      String
  league        League             @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  homeTeamId    String?
  awayTeamId    String?
  homeTeamName  String
  awayTeamName  String
  homeTeam      Team?              @relation("MatchHomeTeam", fields: [homeTeamId], references: [id], onDelete: SetNull)
  awayTeam      Team?              @relation("MatchAwayTeam", fields: [awayTeamId], references: [id], onDelete: SetNull)
  homeScore     Int?
  awayScore     Int?
  scoreText     String?
  statLine      String?
  insight       String?
  adminVisible  Boolean            @default(true)
  adminLockedFields String?
  adminOverrideJson String?
  adminNote     String?
  adminEditedAt DateTime?
  lastSyncedAt  DateTime?
  oddsSnapshots OddsSnapshot[]
  predictions   PredictionRecord[]
  schedules     ScheduleSnapshot[]
  homepageFeaturedSlots HomepageFeaturedMatchSlot[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([source, sourceKey])
  @@index([sport, kickoff])
  @@index([leagueId, kickoff])
  @@index([status, kickoff])
  @@index([adminVisible, kickoff])
  @@index([updatedAt, adminEditedAt])
}

model OddsSnapshot {
  id            String   @id @default(cuid())
  source        String   @default("nowscore")
  sourceKey     String?
  sourcePayload String?
  bookmaker     String?
  market        String   @default("main")
  home          Float?
  draw          Float?
  away          Float?
  spread        String?
  total         String?
  movement      String?
  capturedAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  matchId       String
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, capturedAt])
}

model StandingSnapshot {
  id            String   @id @default(cuid())
  source        String   @default("nowscore")
  sourcePayload String?
  scope         String   @default("overall")
  rank          Int
  teamName      String
  played        Int      @default(0)
  win           Int      @default(0)
  draw          Int      @default(0)
  loss          Int      @default(0)
  points        Int      @default(0)
  form          String?
  homeRecord    String?
  awayRecord    String?
  capturedAt    DateTime @default(now())
  leagueId      String
  teamId        String?
  league        League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team          Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([leagueId, capturedAt, rank])
  @@index([teamId, capturedAt])
}

model ScheduleSnapshot {
  id            String   @id @default(cuid())
  source        String   @default("nowscore")
  sourcePayload String?
  labelDate     String
  fixture       String
  result        String
  note          String
  sortDate      DateTime?
  capturedAt    DateTime @default(now())
  leagueId      String
  matchId       String?
  league        League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  match         Match?   @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([leagueId, capturedAt])
  @@index([matchId])
}

model HeadToHeadSnapshot {
  id            String   @id @default(cuid())
  source        String   @default("nowscore")
  sourcePayload String?
  season        String
  fixture       String
  tag           String
  sortOrder     Int      @default(0)
  capturedAt    DateTime @default(now())
  leagueId      String
  league        League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId, capturedAt, sortOrder])
}

model AuthorTeam {
  id            String             @id @default(cuid())
  source        String             @default("manual")
  sourceKey     String?
  name          String
  slug          String             @unique
  focus         String
  streak        String
  winRate       String
  monthlyRoi    String
  followers     String
  badge         String
  bio           String?
  status        String             @default("active")
  articlePlans  ArticlePlan[]
  predictions   PredictionRecord[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([source, sourceKey])
  @@index([status, updatedAt])
}

model PredictionRecord {
  id            String      @id @default(cuid())
  source        String      @default("manual")
  sourceKey     String?
  sport         String
  market        String
  pick          String
  confidence    String
  expectedEdge  String
  explanation   String
  factorsText   String
  result        String
  publishedAt   DateTime?
  sourcePayload String?
  matchId       String?
  authorId      String?
  match         Match?      @relation(fields: [matchId], references: [id], onDelete: SetNull)
  author        AuthorTeam? @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([source, sourceKey])
  @@index([sport, createdAt])
  @@index([matchId])
  @@index([authorId])
}

model ArticlePlan {
  id               String      @id @default(cuid())
  source           String      @default("manual")
  sourceKey        String?
  slug             String      @unique
  sport            String
  matchId          String?
  title            String
  leagueLabel      String
  kickoff          DateTime
  teaser           String
  marketSummary    String
  previewText      String?
  fullAnalysisText String
  price            Int
  isHot            Boolean     @default(false)
  performance      String
  tagsText         String
  status           String      @default("draft")
  publishedAt      DateTime?
  leagueId         String?
  authorId         String
  league           League?     @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  author           AuthorTeam  @relation(fields: [authorId], references: [id], onDelete: Restrict)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([source, sourceKey])
  @@index([sport, status, kickoff])
  @@index([authorId, status])
  @@index([matchId])
}

model HomepageFeaturedMatchSlot {
  id        String   @id @default(cuid())
  key       String   @unique
  matchRef  String
  status    String   @default("active")
  sortOrder Int      @default(0)
  matchId   String?
  match     Match?   @relation(fields: [matchId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, sortOrder])
  @@index([matchId])
}

model HomepageModule {
  id          String   @id @default(cuid())
  key         String   @unique
  eyebrow     String
  title       String
  description String
  href        String
  metric      String
  status      String   @default("active")
  sortOrder   Int      @default(0)
  leagueId    String?
  league      League?  @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, sortOrder])
}

model HomepageBanner {
  id             String   @id @default(cuid())
  key            String   @unique
  theme          String   @default("sunrise")
  titleZhCn      String
  titleZhTw      String
  titleEn        String
  subtitleZhCn   String
  subtitleZhTw   String
  subtitleEn     String
  descriptionZhCn String
  descriptionZhTw String
  descriptionEn   String
  href           String
  ctaLabelZhCn   String
  ctaLabelZhTw   String
  ctaLabelEn     String
  imageUrl       String
  startsAt       DateTime?
  endsAt         DateTime?
  status         String   @default("active")
  sortOrder      Int      @default(0)
  impressionCount Int     @default(0)
  clickCount      Int     @default(0)
  primaryImpressionCount Int @default(0)
  primaryClickCount      Int @default(0)
  secondaryImpressionCount Int @default(0)
  secondaryClickCount      Int @default(0)
  lastImpressionAt DateTime?
  lastClickAt      DateTime?
  dailyStats       HomepageBannerDailyStat[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, sortOrder])
  @@index([startsAt, endsAt])
}

model HomepageBannerDailyStat {
  id              String         @id @default(cuid())
  metricDate      DateTime
  impressionCount Int            @default(0)
  clickCount      Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  bannerId        String
  banner          HomepageBanner @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  @@unique([bannerId, metricDate])
  @@index([metricDate])
}

model SiteAnnouncement {
  id           String   @id @default(cuid())
  key          String   @unique
  tone         String   @default("info")
  titleZhCn    String
  titleZhTw    String
  titleEn      String
  messageZhCn  String
  messageZhTw  String
  messageEn    String
  href         String?
  ctaLabelZhCn String?
  ctaLabelZhTw String?
  ctaLabelEn   String?
  startsAt     DateTime?
  endsAt       DateTime?
  status       String   @default("active")
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, sortOrder])
  @@index([startsAt, endsAt])
}

model SyncRun {
  id          String   @id @default(cuid())
  source      String   @default("nowscore")
  scope       String
  status      String   @default("running")
  triggerSource String @default("manual-admin")
  requestedByUserId String?
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  summaryJson String?
  errorText   String?

  @@index([source, startedAt])
  @@index([status, startedAt])
}

model SyncLock {
  key        String   @id
  source     String
  scope      String
  runId      String
  owner      String?
  acquiredAt DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
}

model AssistantConversation {
  id                 String                   @id @default(cuid())
  sessionKey         String
  locale             String                   @default("zh-CN")
  title              String?
  summary            String?
  status             String                   @default("open")
  handoffRequestedAt DateTime?
  resolvedAt         DateTime?
  lastMessageAt      DateTime                 @default(now())
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  userId             String?
  user               User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages           AssistantMessage[]
  handoffRequests    AssistantHandoffRequest[]

  @@index([sessionKey, updatedAt])
  @@index([status, updatedAt])
  @@index([userId, updatedAt])
}

model AssistantMessage {
  id             String                @id @default(cuid())
  role           String
  content        String
  linksJson      String?
  provider       String?
  model          String?
  finishReason   String?
  createdAt      DateTime              @default(now())
  conversationId String
  conversation   AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model SupportKnowledgeItem {
  id           String   @id @default(cuid())
  key          String   @unique
  category     String   @default("general")
  questionZhCn String
  questionZhTw String
  questionEn   String
  answerZhCn   String
  answerZhTw   String
  answerEn     String
  href         String?
  tagsText     String?
  status       String   @default("active")
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, sortOrder])
}

model AssistantHandoffRequest {
  id            String                @id @default(cuid())
  locale        String                @default("zh-CN")
  contactName   String?
  contactMethod String?
  note          String?
  status        String                @default("pending")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  conversationId String
  userId        String?
  conversation  AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user          User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, updatedAt])
  @@index([conversationId, updatedAt])
  @@index([userId, updatedAt])
}
